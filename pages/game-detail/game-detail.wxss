/* pages/game-detail/game-detail.wxss */
.detail-container {
  min-height: 100vh;
  padding: 0 0 80rpx;
}

.detail-header {
  padding: 40rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-game-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
}

.detail-date {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

.detail-status {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  width: fit-content;
}

.status-finished { background: rgba(46,213,115,0.15); color: #2ed573; }
.status-playing { background: rgba(245,197,24,0.15); color: #f5c518; }
.status-cancelled { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.4); }

/* 冠军卡 */
.champion-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, rgba(245,197,24,0.15), rgba(233,69,96,0.10));
  border: 1rpx solid rgba(245,197,24,0.35);
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.champion-crown {
  font-size: 56rpx;
  line-height: 1;
}

.champion-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #f5c518;
}

.champion-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
}

.champion-score {
  font-size: 48rpx;
  font-weight: 900;
  color: #f5c518;
}

.champion-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

/* 个人排行 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 8rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.rank-row.rank-1st { background: rgba(245,197,24,0.10); border-color: rgba(245,197,24,0.3); }
.rank-row.rank-2nd { background: rgba(192,192,192,0.07); border-color: rgba(192,192,192,0.25); }
.rank-row.rank-3rd { background: rgba(205,127,50,0.07); border-color: rgba(205,127,50,0.25); }

.rank-icon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.rank-player-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-player-score {
  font-size: 34rpx;
  font-weight: 800;
  color: #f5c518;
  flex-shrink: 0;
}

/* 玩家详情 */
.players-detail-card {
  margin: 0 24rpx 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.pdc-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  margin-bottom: 20rpx;
}

.players-table {}

.pt-header {
  display: flex;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  margin-bottom: 12rpx;
}

.pt-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}

.pt-cell {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.pt-header .pt-cell { font-size: 22rpx; color: rgba(255,255,255,0.35); }

.w40 { width: 40%; }
.w20 { width: 20%; }
.right { text-align: right; }

.player-col {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.pt-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.pt-name {
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.team-A { background: rgba(52,152,219,0.2); color: #3498db; }
.team-B { background: rgba(233,69,96,0.2); color: #e94560; }

.score-txt { font-size: 28rpx; font-weight: 700; }
.pos { color: #2ed573; }
.zero { color: rgba(255,255,255,0.25); }

.rank-txt { font-size: 24rpx; }
.rank-c1 { color: #f5c518; }
.rank-c2 { color: #bdc3c7; }
.rank-c3 { color: #cd7f32; }
.rank-c4 { color: rgba(255,255,255,0.3); }

/* 逐局记录 */
.rounds-card {
  margin: 0 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.rc-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  margin-bottom: 20rpx;
}

.rounds-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.round-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}

.round-row-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rr-num {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  width: 72rpx;
  flex-shrink: 0;
}

.rr-case {
  flex: 1;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

.rr-deltas {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
  margin-top: 8rpx;
}

.rr-delta {
  font-size: 22rpx;
  font-weight: 600;
}
