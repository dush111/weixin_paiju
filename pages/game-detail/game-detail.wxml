<!-- pages/game-detail/game-detail.wxml -->
<view class="container detail-container">

  <!-- 顶部信息 -->
  <view class="detail-header">
    <text class="detail-game-name">{{game.name}}</text>
    <text class="detail-date">{{game.formattedDate}}</text>
    <view class="detail-status status-{{game.status}}">{{game.statusText}}</view>
  </view>

  <!-- 个人积分冠军展示 -->
  <view class="champion-card" wx:if="{{game.players && game.players.length > 0}}">
    <view class="champion-crown">🏆</view>
    <image class="champion-avatar" src="{{game.players[0].avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
    <text class="champion-name">{{game.players[0].nickname}}</text>
    <text class="champion-score">{{game.players[0].score || 0}} 分</text>
    <text class="champion-label">本局冠军</text>
  </view>

  <!-- 个人积分排行 -->
  <view class="players-detail-card">
    <text class="pdc-title">个人积分排名</text>
    <view class="rank-list">
      <view class="rank-row {{item.rankPos === 0 ? 'rank-1st' : item.rankPos === 1 ? 'rank-2nd' : item.rankPos === 2 ? 'rank-3rd' : ''}}"
        wx:for="{{game.players}}" wx:key="openid"
      >
        <text class="rank-icon">{{item.rankIcon}}</text>
        <image class="pt-avatar" src="{{item.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
        <text class="rank-player-name">{{item.nickname}}</text>
        <text class="rank-player-score">{{item.score || 0}}</text>
      </view>
    </view>
  </view>

  <!-- 逐局记录 -->
  <view class="rounds-card" wx:if="{{game.rounds && game.rounds.length > 0}}">
    <text class="rc-title">逐局记录（共{{game.rounds.length}}局）</text>
    <view class="rounds-list">
      <view class="round-row" wx:for="{{game.rounds}}" wx:key="roundNumber">
        <view class="round-row-top">
          <text class="rr-num">第{{item.roundNumber}}局</text>
          <text class="rr-case">{{item.caseText}}</text>
        </view>
        <view class="rr-deltas">
          <text
            class="rr-delta {{delta > 0 ? 'pos' : 'zero'}}"
            wx:for="{{item.playerDeltas}}"
            wx:key="*this"
            wx:for-item="delta"
            wx:for-index="di"
          >{{item.playerDeltaNames[di]}}: {{delta > 0 ? '+' + delta : '0'}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
