<!-- pages/login/login.wxml -->
<view class="container login-container">
  <!-- 顶部装饰 -->
  <view class="top-decoration">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-icon">
      <text class="logo-emoji">🎴</text>
    </view>
    <text class="app-name">转蛋计分</text>
    <text class="app-tagline">掼蛋计分记录神器</text>
  </view>

  <!-- 第一步：欢迎卡片（未登录时） -->
  <view class="login-card" wx:if="{{step === 1}}">
    <view class="card-header">
      <text class="card-title">欢迎使用</text>
      <text class="card-desc">使用微信登录，自动同步您的记录</text>
    </view>

    <!-- 特性列表 -->
    <view class="features-list">
      <view class="feature-item">
        <text class="feature-icon">📊</text>
        <view class="feature-text">
          <text class="feature-name">实时记分</text>
          <text class="feature-desc">4人联机实时同步</text>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🏆</text>
        <view class="feature-text">
          <text class="feature-name">年度战绩</text>
          <text class="feature-desc">数据统计一目了然</text>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📱</text>
        <view class="feature-text">
          <text class="feature-name">扫码加入</text>
          <text class="feature-desc">邀请好友极速加入</text>
        </view>
      </view>
    </view>

    <!-- 微信登录按钮 -->
    <button
      class="btn-wechat-login {{!agreed ? 'btn-wechat-disabled' : ''}}"
      bindtap="doWxLogin"
      disabled="{{!agreed}}"
      wx:if="{{!isLoading}}"
    >微信一键登录</button>

    <!-- 加载状态 -->
    <view class="loading-btn" wx:if="{{isLoading}}">
      <view class="loading-spinner"></view>
      <text>登录中...</text>
    </view>

    <!-- 协议勾选行 -->
    <view class="agree-row" bindtap="toggleAgreed">
      <view class="agree-circle {{agreed ? 'agree-circle-checked' : ''}}">
        <text class="agree-check-icon" wx:if="{{agreed}}">✓</text>
      </view>
      <text class="agree-text">登录即表示同意</text>
      <text class="agree-link" catchtap="showUserAgreement">《用户协议》</text>
      <text class="agree-text">和</text>
      <text class="agree-link" catchtap="showPrivacyPolicy">《隐私政策》</text>
    </view>
  </view>

  <!-- 用户协议弹窗 -->
  <view class="agreement-mask" wx:if="{{showAgreement}}" bindtap="closeAgreement">
    <view class="agreement-box" catchtap="">
      <text class="agreement-title">用户协议</text>
      <scroll-view class="agreement-scroll" scroll-y>
        <text class="agreement-content">{{agreementText}}</text>
      </scroll-view>
      <button class="agreement-close-btn" bindtap="closeAgreement">我知道了</button>
    </view>
  </view>

  <!-- 隐私政策弹窗 -->
  <view class="agreement-mask" wx:if="{{showPrivacy}}" bindtap="closePrivacy">
    <view class="agreement-box" catchtap="">
      <text class="agreement-title">隐私政策</text>
      <scroll-view class="agreement-scroll" scroll-y>
        <text class="agreement-content">{{privacyText}}</text>
      </scroll-view>
      <button class="agreement-close-btn" bindtap="closePrivacy">我知道了</button>
    </view>
  </view>

  <!-- 第二步：填写昵称和头像 -->
  <view class="login-card profile-card" wx:if="{{step === 2}}">
    <view class="card-header">
      <text class="card-title">完善资料</text>
      <text class="card-desc">设置您的头像和昵称，让队友认识你</text>
    </view>

    <!-- 头像选择 -->
    <view class="avatar-section">
      <button
        class="avatar-wrap"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <image
          wx:if="{{tempAvatarUrl}}"
          class="avatar-img"
          src="{{tempAvatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-placeholder-icon">📷</text>
          <text class="avatar-placeholder-text">点击选择头像</text>
        </view>
        <view class="avatar-edit-badge">✎</view>
      </button>
      <text class="avatar-hint">点击头像使用微信头像</text>
    </view>

    <!-- 昵称输入（type="nickname" 可呼起微信键盘填充昵称） -->
    <view class="nickname-section">
      <text class="field-label">昵称</text>
      <view class="nickname-input-wrap">
        <input
          class="nickname-input"
          type="nickname"
          placeholder="点击填写或使用微信昵称"
          placeholder-class="input-placeholder"
          value="{{tempNickname}}"
          bindinput="onNicknameInput"
          bindblur="onNicknameBlur"
          maxlength="20"
          confirm-type="done"
        />
        <text class="input-count">{{tempNickname.length}}/20</text>
      </view>
    </view>

    <!-- 确认按钮 -->
    <button
      class="btn-confirm {{(!tempNickname || isLoading) ? 'btn-disabled' : ''}}"
      bindtap="confirmProfile"
      disabled="{{!tempNickname || isLoading}}"
    >
      <text wx:if="{{!isLoading}}">开始使用 →</text>
      <view wx:else class="loading-inline">
        <view class="loading-spinner-sm"></view>
        <text>保存中...</text>
      </view>
    </button>

    <text class="privacy-text">昵称将展示给同局玩家</text>
  </view>

  <!-- 底部版本 -->
  <view class="footer">
    <text class="version-text">v1.0.0</text>
  </view>
</view>
