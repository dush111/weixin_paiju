/* pages/login/login.wxss */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 0 48rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰圆 */
.top-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 500rpx;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(233, 69, 96, 0.15);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -80rpx;
}

.circle-2 {
  width: 280rpx;
  height: 280rpx;
  top: 60rpx;
  left: -60rpx;
  background: rgba(255, 255, 255, 0.05);
}

.circle-3 {
  width: 180rpx;
  height: 180rpx;
  top: 200rpx;
  right: 60rpx;
  background: rgba(233, 69, 96, 0.08);
}

/* Logo */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 140rpx;
  margin-bottom: 56rpx;
  z-index: 1;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(233, 69, 96, 0.5);
  margin-bottom: 28rpx;
}

.logo-emoji {
  font-size: 80rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.app-tagline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

/* 卡片通用 */
.login-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.07);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(20px);
  z-index: 1;
}

.card-header {
  margin-bottom: 40rpx;
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 特性列表 */
.features-list {
  margin-bottom: 44rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.feature-text {
  display: flex;
  flex-direction: column;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

/* 微信登录按钮 */
.btn-wechat-login {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.4);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.btn-wechat-login::after {
  border: none;
}

.wechat-icon {
  background: rgba(255, 255, 255, 0.25);
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
  font-size: 22rpx;
  font-weight: 700;
}

/* 加载按钮 */
.loading-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 30rpx;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #e94560;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 第二步：完善资料 ===== */
.profile-card {
  padding-bottom: 40rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  background: transparent;
  border: none;
  margin-bottom: 16rpx;
  overflow: visible;
}

.avatar-wrap::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(233, 69, 96, 0.5);
  display: block;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx dashed rgba(255, 255, 255, 0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.avatar-placeholder-icon {
  font-size: 48rpx;
}

.avatar-placeholder-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e94560;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #1a1a2e;
}

.avatar-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* 昵称输入 */
.nickname-section {
  margin-bottom: 44rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.65);
  margin-bottom: 16rpx;
}

.nickname-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 0 28rpx;
  height: 96rpx;
  transition: border-color 0.2s;
}

.nickname-input-wrap:focus-within {
  border-color: rgba(233, 69, 96, 0.6);
}

.nickname-input {
  flex: 1;
  font-size: 32rpx;
  color: #ffffff;
  height: 96rpx;
  line-height: 96rpx;
}

.input-placeholder {
  color: rgba(255, 255, 255, 0.25);
  font-size: 30rpx;
}

.input-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.25);
  flex-shrink: 0;
}

/* 确认按钮 */
.btn-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(233, 69, 96, 0.4);
  margin-bottom: 24rpx;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm:active {
  transform: scale(0.97);
  opacity: 0.88;
}

.btn-disabled {
  background: rgba(255, 255, 255, 0.1) !important;
  color: rgba(255, 255, 255, 0.3) !important;
  box-shadow: none !important;
}

.loading-inline {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner-sm {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 通用 */
.privacy-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 协议勾选行 */
.agree-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 20rpx;
  gap: 4rpx;
}

.agree-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  flex-shrink: 0;
  transition: background 0.2s, border-color 0.2s;
}

.agree-circle-checked {
  background: #07c160;
  border-color: #07c160;
}

.agree-check-icon {
  font-size: 22rpx;
  color: #fff;
  line-height: 1;
}

.agree-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

.agree-link {
  font-size: 22rpx;
  color: #e94560;
}

/* 登录按钮禁用态 */
.btn-wechat-disabled {
  background: rgba(255, 255, 255, 0.1) !important;
  color: rgba(255, 255, 255, 0.3) !important;
  box-shadow: none !important;
}

/* 协议/隐私弹窗 */
.agreement-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 60rpx 40rpx;
}

.agreement-box {
  width: 100%;
  background: #1e1e3a;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  flex-direction: column;
  max-height: 70vh;
}

.agreement-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin-bottom: 32rpx;
  flex-shrink: 0;
}

.agreement-scroll {
  flex: 1;
  min-height: 0;
  max-height: 50vh;
}

.agreement-content {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.8;
  white-space: pre-wrap;
}

.agreement-close-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  flex-shrink: 0;
}

.agreement-close-btn::after {
  border: none;
}

/* 底部 */
.footer {
  margin-top: 48rpx;
  z-index: 1;
}

.version-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}
