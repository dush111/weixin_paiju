/* pages/login/login.wxss */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 0 48rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰圆 */
.top-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 500rpx;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(233, 69, 96, 0.15);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -80rpx;
}

.circle-2 {
  width: 280rpx;
  height: 280rpx;
  top: 60rpx;
  left: -60rpx;
  background: rgba(255, 255, 255, 0.05);
}

.circle-3 {
  width: 180rpx;
  height: 180rpx;
  top: 200rpx;
  right: 60rpx;
  background: rgba(233, 69, 96, 0.08);
}

/* Logo */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 160rpx;
  margin-bottom: 60rpx;
  z-index: 1;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(233, 69, 96, 0.5);
  margin-bottom: 28rpx;
}

.logo-emoji {
  font-size: 80rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.app-tagline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.07);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(20px);
  z-index: 1;
}

.card-header {
  margin-bottom: 40rpx;
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 特性列表 */
.features-list {
  margin-bottom: 44rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.feature-text {
  display: flex;
  flex-direction: column;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

/* 微信登录按钮 */
.btn-wechat-login {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.4);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.btn-wechat-login::after {
  border: none;
}

.wechat-icon {
  background: rgba(255,255,255,0.25);
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.loading-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50rpx;
  color: rgba(255,255,255,0.6);
  font-size: 30rpx;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255,255,255,0.2);
  border-top-color: #e94560;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.privacy-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 底部 */
.footer {
  margin-top: 48rpx;
  z-index: 1;
}

.version-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}
