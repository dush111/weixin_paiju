/* pages/home/home.wxss */
.home-container {
  min-height: 100vh;
  padding: 0 0 120rpx;
}

/* 顶部用户信息 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 40rpx 36rpx;
  background: linear-gradient(180deg, rgba(233,69,96,0.15) 0%, transparent 100%);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(233, 69, 96, 0.6);
}

.username {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.user-level {
  font-size: 24rpx;
  color: #f5c518;
}

.score-badge {
  background: linear-gradient(135deg, rgba(233,69,96,0.3), rgba(233,69,96,0.15));
  border: 1rpx solid rgba(233,69,96,0.4);
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  text-align: center;
}

.score-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 4rpx;
}

.score-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #f5c518;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 退出登录按钮 */
.logout-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn:active {
  background: rgba(233, 69, 96, 0.2);
  border-color: rgba(233, 69, 96, 0.4);
}

.logout-icon {
  font-size: 28rpx;
  display: block;
  color: rgba(255, 255, 255, 0.6);
}

/* 加入牌局卡片（与新建并列，全宽各占一半） */
.menu-card-join {
  background: linear-gradient(135deg, rgba(243,156,18,0.3), rgba(230,126,34,0.2));
  border-color: rgba(243, 156, 18, 0.4);
}

.orange-bg { background: rgba(243, 156, 18, 0.35); }

.today-stats {
  margin: 0 32rpx 32rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.stats-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
}

.stats-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #ffffff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.12);
}

.text-gold { color: #f5c518; }
.text-red { color: #e94560; }

/* 菜单网格 */
.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.menu-card {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
}

.menu-card:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.menu-card-primary {
  background: linear-gradient(135deg, rgba(233,69,96,0.35), rgba(192,57,43,0.2));
  border-color: rgba(233,69,96,0.4);
}

.menu-icon-bg {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.primary-bg { background: rgba(233, 69, 96, 0.4); }
.blue-bg { background: rgba(52, 152, 219, 0.35); }
.purple-bg { background: rgba(155, 89, 182, 0.35); }
.green-bg { background: rgba(46, 213, 115, 0.3); }

.menu-icon {
  font-size: 44rpx;
}

.menu-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.menu-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.menu-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: rgba(255,255,255,0.3);
}

/* 进行中的房间 */
.active-section {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.active-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2ecc71;
  box-shadow: 0 0 0 4rpx rgba(46, 204, 113, 0.3);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 4rpx rgba(46, 204, 113, 0.3); }
  50% { box-shadow: 0 0 0 10rpx rgba(46, 204, 113, 0.1); }
}

.active-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.active-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(46,204,113,0.12), rgba(39,174,96,0.06));
  border: 1rpx solid rgba(46, 204, 113, 0.3);
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  transition: all 0.2s;
}

.active-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(46,204,113,0.2), rgba(39,174,96,0.1));
}

.active-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  overflow: hidden;
}

.active-status-badge {
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.badge-playing {
  background: rgba(46, 204, 113, 0.25);
  color: #2ecc71;
  border: 1rpx solid rgba(46, 204, 113, 0.4);
}

.badge-waiting {
  background: rgba(245, 197, 24, 0.2);
  color: #f5c518;
  border: 1rpx solid rgba(245, 197, 24, 0.35);
}

.active-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}

.active-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.active-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.active-right {
  flex-shrink: 0;
  margin-left: 20rpx;
}

.btn-resume {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  border-radius: 40rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.4);
}

/* 最近牌局 */
.recent-section {
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.section-more {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 12rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-text {
  font-size: 30rpx;
  color: rgba(255,255,255,0.45);
}
.empty-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.25);
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.recent-item:active {
  background: rgba(255,255,255,0.1);
}

.recent-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.rank-badge {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.rank-1 { background: linear-gradient(135deg, #f5c518, #e67e22); color: #fff; }
.rank-2 { background: linear-gradient(135deg, #bdc3c7, #95a5a6); color: #fff; }
.rank-3 { background: linear-gradient(135deg, #cd7f32, #a04000); color: #fff; }
.rank-4 { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); }

.recent-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.recent-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.recent-players {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.recent-score {
  font-size: 36rpx;
  font-weight: 800;
}

.score-pos { color: #2ecc71; }
.score-neg { color: #e94560; }

.recent-rounds {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}
