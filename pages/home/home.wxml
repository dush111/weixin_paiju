<!-- pages/home/home.wxml -->
<view class="container home-container">
  <!-- 顶部用户信息 -->
  <view class="header">
    <view class="user-info" bindtap="onAvatarTap">
      <!-- 未登录：默认头像 + 点击登录提示 -->
      <view class="avatar-wrap">
        <image
          class="avatar"
          src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}"
          mode="aspectFill"
        ></image>
        <view class="login-hint" wx:if="{{!isLoggedIn}}">
          <text class="login-hint-text">点击登录</text>
        </view>
      </view>
      <view class="user-meta">
        <text class="username">{{isLoggedIn ? (userInfo.nickname || '掼蛋玩家') : '游客'}}</text>
        <text class="user-level">{{isLoggedIn ? rankText : '登录后查看数据'}}</text>
      </view>
    </view>
    <view class="header-right" wx:if="{{isLoggedIn}}">
      <view class="score-badge">
        <text class="score-label">总积分</text>
        <text class="score-value">{{totalScore}}</text>
      </view>
    </view>
    <view class="header-right" wx:else>
      <view class="login-btn-small" bindtap="onAvatarTap">
        <text class="login-btn-small-text">登录</text>
      </view>
    </view>
  </view>

  <!-- 今日数据（已登录时显示） -->
  <view class="today-stats card" wx:if="{{isLoggedIn}}">
    <view class="stats-title">
      <text class="stats-title-text">今日战绩</text>
      <text class="stats-date">{{todayDate}}</text>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{todayStats.games}}</text>
        <text class="stat-label">场次</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num {{todayStats.score >= 0 ? 'text-gold' : 'text-red'}}">{{todayStats.score >= 0 ? '+' : ''}}{{todayStats.score}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{todayStats.wins}}</text>
        <text class="stat-label">胜局</text>
      </view>
    </view>
  </view>

  <!-- 未登录引导卡 -->
  <view class="guest-card" wx:if="{{!isLoggedIn}}">
    <text class="guest-icon">🎴</text>
    <text class="guest-title">开始你的掼蛋之旅</text>
    <text class="guest-desc">登录后可记录牌局、查看战绩、积分排名</text>
    <view class="guest-login-btn" bindtap="onAvatarTap">
      <text>微信登录</text>
    </view>
  </view>

  <!-- 进行中 / 等待中的房间：有时置顶 -->
  <view class="active-section" wx:if="{{isLoggedIn && activeGames.length > 0}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="active-dot"></view>
        <text class="section-title">进行中的房间</text>
      </view>
    </view>
    <view class="active-list">
      <view
        class="active-item"
        wx:for="{{activeGames}}"
        wx:key="_id"
        bindtap="resumeGame"
        data-id="{{item._id}}"
        data-status="{{item.status}}"
      >
        <view class="active-left">
          <view class="active-status-badge {{item.status === 'playing' ? 'badge-playing' : 'badge-waiting'}}">
            <text>{{item.status === 'playing' ? '进行中' : '等待中'}}</text>
          </view>
          <view class="active-info">
            <text class="active-name">{{item.name || '掼蛋牌局'}}</text>
            <text class="active-meta">{{item.playersText}} · 第{{item.currentRound}}局</text>
          </view>
        </view>
        <view class="active-right">
          <view class="btn-resume">
            <text>继续 ›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 主菜单按钮 -->
  <view class="menu-grid">
    <!-- 新建牌局 -->
    <view class="menu-card menu-card-primary" bindtap="createGame">
      <view class="menu-icon-bg primary-bg">
        <text class="menu-icon">🎯</text>
      </view>
      <text class="menu-name">新建牌局</text>
      <text class="menu-desc">邀请3位玩家开始</text>
      <view class="menu-arrow">›</view>
    </view>

    <!-- 加入牌局 -->
    <view class="menu-card menu-card-join" bindtap="joinGame">
      <view class="menu-icon-bg orange-bg">
        <text class="menu-icon">🚪</text>
      </view>
      <text class="menu-name">加入牌局</text>
      <text class="menu-desc">输入邀请码或扫码</text>
      <view class="menu-arrow">›</view>
    </view>

    <!-- 我的牌局 -->
    <view class="menu-card" bindtap="goToMyGames">
      <view class="menu-icon-bg blue-bg">
        <text class="menu-icon">📋</text>
      </view>
      <text class="menu-name">我的牌局</text>
      <text class="menu-desc">历史记录查看</text>
      <view class="menu-arrow">›</view>
    </view>

    <!-- 年度战绩 -->
    <view class="menu-card" bindtap="goToAnnualStats">
      <view class="menu-icon-bg purple-bg">
        <text class="menu-icon">📊</text>
      </view>
      <text class="menu-name">年度战绩</text>
      <text class="menu-desc">数据统计分析</text>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 最近牌局（已登录时显示） -->
  <view class="recent-section" wx:if="{{isLoggedIn}}">
    <view class="section-header">
      <text class="section-title">最近牌局</text>
      <text class="section-more" bindtap="goToMyGames">查看全部 ›</text>
    </view>

    <view wx:if="{{recentGames.length === 0}}" class="empty-state">
      <text class="empty-icon">🃏</text>
      <text class="empty-text">还没有牌局记录</text>
      <text class="empty-sub">点击「新建牌局」开始第一局</text>
    </view>

    <view wx:else class="recent-list">
      <view
        class="recent-item"
        wx:for="{{recentGames}}"
        wx:key="_id"
        bindtap="goToGameDetail"
        data-id="{{item._id}}"
      >
        <view class="recent-left">
          <view class="rank-badge rank-{{item.myRank}}">{{item.myRank}}</view>
          <view class="recent-info">
            <text class="recent-date">{{item.formattedDate}}</text>
            <text class="recent-players">{{item.playersText}}</text>
          </view>
        </view>
        <view class="recent-right">
          <text class="recent-score {{item.score >= 0 ? 'score-pos' : 'score-neg'}}">
            {{item.score >= 0 ? '+' : ''}}{{item.score}}
          </text>
          <text class="recent-rounds">{{item.rounds}}局</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 进行中的房间为空时底部提示（已登录时显示） -->
  <view class="active-section active-section-bottom" wx:if="{{isLoggedIn && activeGames.length === 0}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="active-dot inactive-dot"></view>
        <text class="section-title">进行中的房间</text>
      </view>
    </view>
    <view class="empty-active">
      <text class="empty-active-text">暂无进行中的房间</text>
      <text class="empty-active-sub">新建或加入牌局后将在此显示</text>
    </view>
  </view>
</view>
