/* pages/scoring/scoring.wxss */
.scoring-container {
  min-height: 100vh;
  padding: 0 0 80rpx;
}

/* 顶部状态 */
.top-bar {
  background: rgba(255,255,255,0.06);
  padding: 40rpx 40rpx 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.game-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.game-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.round-info {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

.progress-bar {
  height: 6rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #f5c518);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

/* 设置行：计划局数 + 级牌 */
.settings-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.setting-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 12rpx;
  padding: 10rpx 18rpx;
  flex: 1;
}

.setting-chip-host {
  border-color: rgba(245,197,24,0.3);
  background: rgba(245,197,24,0.06);
}

.setting-chip-host:active {
  background: rgba(245,197,24,0.14);
}

.setting-chip-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  flex-shrink: 0;
}

.setting-chip-val {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
}

.level-val {
  color: #f5c518;
  font-size: 30rpx;
}

.setting-chip-edit {
  font-size: 20rpx;
  color: rgba(245,197,24,0.6);
  flex-shrink: 0;
}

/* 队伍总览 */
.teams-overview {
  display: flex;
  align-items: stretch;
  padding: 32rpx 24rpx;
  gap: 0;
}

.team-card {
  flex: 1;
  background: rgba(255,255,255,0.05);
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
  border: 1rpx solid rgba(255,255,255,0.08);
  transition: all 0.3s;
}

.team-card.team-leading {
  background: rgba(233,69,96,0.12);
  border-color: rgba(233,69,96,0.4);
}

.team-a.team-leading { background: rgba(52,152,219,0.12); border-color: rgba(52,152,219,0.4); }
.team-b.team-leading { background: rgba(233,69,96,0.12); border-color: rgba(233,69,96,0.4); }

.team-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.team-score {
  font-size: 72rpx;
  font-weight: 900;
  color: #ffffff;
  line-height: 1;
}

.team-players {
  display: flex;
  align-items: center;
}

.team-player-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-player-sep {
  font-size: 20rpx;
  color: rgba(255,255,255,0.25);
  padding: 0 4rpx;
}

.win-crown {
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
}

.vs-divider {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.vs-text {
  font-size: 28rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.25);
}

/* 记分输入区 */
.score-input-section {
  padding: 0 32rpx 32rpx;
  background: rgba(255,255,255,0.03);
  margin: 0 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.score-rule-btn {
  font-size: 24rpx;
  color: #e94560;
  background: rgba(233,69,96,0.15);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  margin-bottom: 20rpx;
}

/* 名次块 */
.rank-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.rank-block {
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.07);
  padding: 20rpx;
}

.rank-block-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.rank-block-icon {
  font-size: 36rpx;
  line-height: 1;
}

.rank-block-label {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
}

.rank-block-selected {
  margin-left: auto;
  font-size: 22rpx;
  color: #2ed573;
  background: rgba(46,213,115,0.12);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.rank-block-unselected {
  margin-left: auto;
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
}

/* 四个头像一排 */
.avatar-pick-row {
  display: flex;
  justify-content: space-around;
  gap: 8rpx;
}

.avatar-pick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  flex: 1;
  transition: all 0.15s;
}

/* 选中状态：绿色边框 */
.avatar-pick-item.selected {
  border-color: #2ed573;
  background: rgba(46,213,115,0.12);
}

/* 已被其他名次选中：置灰不可点 */
.avatar-pick-item.disabled {
  opacity: 0.3;
}

.pick-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.15);
}

.avatar-pick-item.selected .pick-avatar {
  border-color: #2ed573;
}

.pick-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.avatar-pick-item.selected .pick-name {
  color: #2ed573;
  font-weight: 600;
}

/* 积分预览 */
.score-preview {
  background: rgba(245,197,24,0.08);
  border: 1rpx solid rgba(245,197,24,0.25);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.preview-title {
  display: block;
  font-size: 24rpx;
  color: rgba(245,197,24,0.8);
  margin-bottom: 12rpx;
}

.preview-teams {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 10rpx;
}

.preview-team {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.preview-team-name {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.preview-score {
  font-size: 44rpx;
  font-weight: 800;
}

.preview-score.pos { color: #2ed573; }
.preview-score.zero { color: rgba(255,255,255,0.3); }

.preview-vs {
  font-size: 24rpx;
  color: rgba(255,255,255,0.2);
}

.preview-case {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

/* 操作按钮行 */
.action-btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.btn-cancel-sel,
.btn-confirm-sel {
  flex: 1;
  height: 96rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cancel-sel {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.75);
}

.btn-cancel-sel::after { border: none; }

.btn-cancel-sel.btn-sel-disabled {
  background: rgba(255,255,255,0.03);
  border-color: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.2);
}

.btn-confirm-sel {
  background: linear-gradient(135deg, #2ed573, #17a84a);
  color: #ffffff;
  border: none;
}

.btn-confirm-sel::after { border: none; }

.btn-confirm-sel.btn-sel-disabled {
  background: rgba(46,213,115,0.12);
  color: rgba(46,213,115,0.3);
}

/* 历史记录 */
.history-section {
  padding: 32rpx 32rpx 0;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.04);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.h-round {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  width: 80rpx;
  flex-shrink: 0;
}

.h-case {
  flex: 1;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  text-align: center;
}

.h-scores {
  display: flex;
  gap: 16rpx;
}

.h-score-a, .h-score-b {
  font-size: 26rpx;
  font-weight: 700;
}

.pos { color: #2ed573; }
.zero { color: rgba(255,255,255,0.25); }

/* 结束牌局 */
.end-game-row {
  padding: 24rpx 32rpx;
}

.btn-end-game {
  width: 100%;
  height: 80rpx;
  background: transparent;
  border: 1rpx solid rgba(233,69,96,0.4);
  border-radius: 50rpx;
  color: rgba(233,69,96,0.7);
  font-size: 28rpx;
}

.btn-end-game::after { border: none; }

/* 规则弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-box {
  background: #1a1a2e;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx 60rpx;
  width: 100%;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 32rpx;
  text-align: center;
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.rule-item {
  padding: 20rpx 0;
}

.rule-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.08);
}

.rule-case {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.case-300 { background: rgba(245,197,24,0.2); color: #f5c518; }
.case-200 { background: rgba(52,152,219,0.2); color: #3498db; }
.case-100 { background: rgba(46,213,115,0.15); color: #2ed573; }

.rule-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  margin-bottom: 4rpx;
}

.rule-formula {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

.rule-note {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  text-align: center;
  margin: 24rpx 0;
}

.modal-close {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.modal-close::after { border: none; }
