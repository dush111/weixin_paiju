<!-- pages/scoring/scoring.wxml -->
<view class="container scoring-container">
  <!-- 顶部状态栏 -->
  <view class="top-bar">
    <view class="game-info">
      <text class="game-name">{{gameName}}</text>
      <text class="round-info">第 {{currentRound}} 局 / 共 {{targetRounds}} 局</text>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPct}}%"></view>
    </view>
  </view>

  <!-- 队伍积分总览 -->
  <view class="teams-overview">
    <view class="team-card team-a {{teamAWinning ? 'team-leading' : ''}}">
      <text class="team-label">A队</text>
      <text class="team-score">{{teamAScore}}</text>
      <view class="team-players">
        <text class="team-player-name">{{players[0] ? players[0].nickname : '玩家1'}}</text>
        <text class="team-player-sep"> & </text>
        <text class="team-player-name">{{players[2] ? players[2].nickname : '玩家3'}}</text>
      </view>
      <view class="win-crown" wx:if="{{teamAWinning}}">👑</view>
    </view>

    <view class="vs-divider">
      <text class="vs-text">VS</text>
    </view>

    <view class="team-card team-b {{!teamAWinning && teamBScore > 0 ? 'team-leading' : ''}}">
      <text class="team-label">B队</text>
      <text class="team-score">{{teamBScore}}</text>
      <view class="team-players">
        <text class="team-player-name">{{players[1] ? players[1].nickname : '玩家2'}}</text>
        <text class="team-player-sep"> & </text>
        <text class="team-player-name">{{players[3] ? players[3].nickname : '玩家4'}}</text>
      </view>
      <view class="win-crown" wx:if="{{!teamAWinning && teamBScore > 0 && teamBScore >= teamAScore}}">👑</view>
    </view>
  </view>

  <!-- 记录本局结果 -->
  <view class="score-input-section">
    <view class="section-title-row">
      <text class="section-title">记录第 {{currentRound}} 局</text>
      <text class="score-rule-btn" bindtap="showRules">积分规则 ?</text>
    </view>

    <!-- 选择本局名次 -->
    <text class="input-hint">点击头像为每个名次选择玩家</text>

    <!-- 名次选择：头像点选 -->
    <view class="rank-selector">
      <view class="rank-block" wx:for="{{rankBlocks}}" wx:key="rank" wx:for-item="block">
        <!-- 名次标题 -->
        <view class="rank-block-header">
          <text class="rank-block-icon">{{block.icon}}</text>
          <text class="rank-block-label">{{block.label}}</text>
          <text class="rank-block-selected" wx:if="{{rankIndexes[block.rank] !== -1}}">
            已选：{{rankSelections[block.rank]}}
          </text>
          <text class="rank-block-unselected" wx:else>未选择</text>
        </view>
        <!-- 四个头像 -->
        <view class="avatar-pick-row">
          <view
            wx:for="{{players}}"
            wx:key="openid"
            wx:for-item="player"
            wx:for-index="pi"
            class="avatar-pick-item
              {{rankIndexes[block.rank] === pi ? 'selected' : ''}}
              {{rankIndexes[block.rank] !== pi && usedIndexes[pi] ? 'disabled' : ''}}"
            bindtap="onPickAvatar"
            data-rank="{{block.rank}}"
            data-pi="{{pi}}"
          >
            <image
              class="pick-avatar"
              src="{{player.avatarUrl || '/assets/images/default-avatar.png'}}"
              mode="aspectFill"
            />
            <text class="pick-name">{{player.nickname}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 积分预览 -->
    <view class="score-preview" wx:if="{{previewReady}}">
      <text class="preview-title">本局积分预览</text>
      <view class="preview-teams">
        <view class="preview-team">
          <text class="preview-team-name">A队</text>
          <text class="preview-score {{previewAScore > 0 ? 'pos' : 'zero'}}">
            {{previewAScore > 0 ? '+' : ''}}{{previewAScore}}
          </text>
        </view>
        <view class="preview-vs">VS</view>
        <view class="preview-team">
          <text class="preview-team-name">B队</text>
          <text class="preview-score {{previewBScore > 0 ? 'pos' : 'zero'}}">
            {{previewBScore > 0 ? '+' : ''}}{{previewBScore}}
          </text>
        </view>
      </view>
      <text class="preview-case">{{scoreCase}}</text>
    </view>

    <!-- 操作按钮组 -->
    <view class="action-btn-row">
      <button
        class="btn-cancel-sel {{selectedCount === 0 ? 'btn-sel-disabled' : ''}}"
        disabled="{{selectedCount === 0}}"
        bindtap="cancelSelection"
      >取消选择</button>
      <button
        class="btn-confirm-sel {{!previewReady ? 'btn-sel-disabled' : ''}}"
        disabled="{{!previewReady}}"
        bindtap="submitRound"
      >确认选择</button>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{rounds.length > 0}}">
    <text class="section-title">历史记录</text>
    <view class="history-list">
      <view class="history-item" wx:for="{{rounds}}" wx:key="roundNumber">
        <text class="h-round">第{{item.roundNumber}}局</text>
        <view class="h-case">{{item.caseText}}</view>
        <view class="h-scores">
          <text class="h-score-a {{item.scoreA > 0 ? 'pos' : 'zero'}}">A: {{item.scoreA > 0 ? '+' : ''}}{{item.scoreA}}</text>
          <text class="h-score-b {{item.scoreB > 0 ? 'pos' : 'zero'}}">B: {{item.scoreB > 0 ? '+' : ''}}{{item.scoreB}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 结束牌局按钮 -->
  <view class="end-game-row">
    <button class="btn-end-game" bindtap="confirmEndGame">结束牌局</button>
  </view>
</view>

<!-- 积分规则弹窗 -->
<view class="modal-mask" wx:if="{{showRuleModal}}" bindtap="hideRules">
  <view class="modal-box" catchtap="">
    <text class="modal-title">积分规则</text>
    <view class="rule-list">
      <view class="rule-item">
        <view class="rule-case case-300">300分局</view>
        <text class="rule-desc">第一、二名同队（一二名均在同队）</text>
        <text class="rule-formula">获胜队 +300，失败队 +0</text>
      </view>
      <view class="rule-divider"></view>
      <view class="rule-item">
        <view class="rule-case case-200">200分局</view>
        <text class="rule-desc">第一、三名同队（一三名均在同队）</text>
        <text class="rule-formula">获胜队 +200，失败队 +0</text>
      </view>
      <view class="rule-divider"></view>
      <view class="rule-item">
        <view class="rule-case case-100">100分局</view>
        <text class="rule-desc">第一、四名同队（队友包揽首末）</text>
        <text class="rule-formula">获胜队 +100，失败队 +0</text>
      </view>
    </view>
    <text class="rule-note">* 没有第一名的队伍不得分</text>
    <button class="modal-close" bindtap="hideRules">我知道了</button>
  </view>
</view>
