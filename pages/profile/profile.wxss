/* pages/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  padding: 0 0 120rpx;
}

/* ─── 登录面板 ─── */
.login-panel {
  padding: 80rpx 48rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
}

.login-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(233,69,96,0.3), rgba(192,57,43,0.2));
  border: 3rpx solid rgba(233, 69, 96, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-emoji {
  font-size: 72rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
}

.logo-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.features-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.feature-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.feature-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

.wx-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #059a4a);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  transition: all 0.2s;
}

.wx-login-btn::after { border: none; }

.wx-login-btn.btn-disabled {
  background: rgba(255, 255, 255, 0.12);
  box-shadow: none;
  color: rgba(255, 255, 255, 0.3);
}

.wx-login-icon {
  font-size: 30rpx;
}

/* 协议行 */
.agreement-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
}

.checkbox-wrap {
  padding: 8rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #e94560;
  border-color: #e94560;
}

.check-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

.agreement-link {
  font-size: 24rpx;
  color: #e94560;
}

/* ─── 设置资料面板 ─── */
.setup-panel {
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
}

.setup-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.setup-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
}

.setup-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.avatar-edit-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.avatar-picker-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  background: transparent;
  border: none;
  overflow: visible;
}

.avatar-picker-btn::after { border: none; }

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(233, 69, 96, 0.6);
  display: block;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #e94560;
  border-radius: 50%;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 700;
  border: 3rpx solid #1a1a2e;
}

.avatar-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

.nickname-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 600;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.btn-confirm {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.4);
}

.btn-confirm::after { border: none; }

.btn-confirm.btn-disabled {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: none;
  color: rgba(255, 255, 255, 0.3);
}

/* ─── 已登录个人中心 ─── */
.profile-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(180deg, rgba(233,69,96,0.12) 0%, transparent 100%);
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(233, 69, 96, 0.6);
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
}

.profile-openid {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

.profile-action-btns {
  flex-shrink: 0;
}

.btn-edit {
  background: rgba(233, 69, 96, 0.2);
  border: 1rpx solid rgba(233, 69, 96, 0.4);
  border-radius: 32rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #e94560;
  font-weight: 600;
}

.btn-edit:active {
  background: rgba(233, 69, 96, 0.35);
}

/* 编辑模式昵称输入 */
.nickname-edit-input {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(233, 69, 96, 0.4);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 32rpx;
  color: #ffffff;
  width: 100%;
}

.input-count-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* 编辑操作栏 */
.edit-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 32rpx;
}

.btn-save {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(233, 69, 96, 0.4);
}

.btn-save::after { border: none; }

.btn-save.btn-disabled {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: none;
  color: rgba(255, 255, 255, 0.3);
}

.btn-cancel-edit {
  flex: 1;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 44rpx;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.btn-cancel-edit::after { border: none; }

/* 功能菜单列表 */
.menu-list {
  margin: 16rpx 32rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 36rpx;
  transition: background 0.2s;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.08);
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-item-icon {
  font-size: 40rpx;
}

.menu-item-name {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 500;
}

.logout-text {
  color: #e94560;
}

.menu-item-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}

.menu-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
  margin: 0 36rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 60rpx 0 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.2);
}

/* ─── 弹窗 ─── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.modal-box {
  width: 100%;
  max-height: 75vh;
  background: #1a1a2e;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.modal-body {
  flex: 1;
  padding: 32rpx 40rpx;
  height: 52vh;
}

.modal-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.8;
  white-space: pre-wrap;
}

.modal-footer {
  padding: 24rpx 40rpx 48rpx;
  flex-shrink: 0;
}

.btn-modal-confirm {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  border: none;
}

.btn-modal-confirm::after { border: none; }
