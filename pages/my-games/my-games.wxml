<!-- pages/my-games/my-games.wxml -->
<view class="container my-games-container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view
      class="filter-btn {{activeFilter === item.key ? 'active' : ''}}"
      wx:for="{{filters}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="setFilter"
    >{{item.label}}</view>
  </view>

  <!-- 统计摘要 -->
  <view class="summary-bar">
    <view class="summary-item">
      <text class="sum-val">{{summary.total}}</text>
      <text class="sum-label">总场次</text>
    </view>
    <view class="sum-divider"></view>
    <view class="summary-item">
      <text class="sum-val text-green">{{summary.wins}}</text>
      <text class="sum-label">胜场</text>
    </view>
    <view class="sum-divider"></view>
    <view class="summary-item">
      <text class="sum-val text-gold">{{summary.totalScore}}</text>
      <text class="sum-label">累计积分</text>
    </view>
    <view class="sum-divider"></view>
    <view class="summary-item">
      <text class="sum-val">{{summary.winRate}}%</text>
      <text class="sum-label">胜率</text>
    </view>
  </view>

  <!-- 牌局列表 -->
  <view wx:if="{{games.length === 0}}" class="empty-state-wrap">
    <text class="empty-emoji">🃏</text>
    <text class="empty-main">暂无牌局记录</text>
    <text class="empty-sub">快去新建一局掼蛋吧！</text>
  </view>

  <scroll-view scroll-y class="games-list" wx:else>
    <view
      class="game-card"
      wx:for="{{games}}"
      wx:key="_id"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <!-- 左侧：名次徽章 -->
      <view class="game-rank-col">
        <view class="rank-circle rank-{{item.myRank}}">{{item.myRank}}</view>
        <text class="rank-label">第{{item.myRank}}名</text>
      </view>

      <!-- 中间：信息 -->
      <view class="game-info-col">
        <text class="game-title">{{item.name}}</text>
        <text class="game-players">{{item.playersText}}</text>
        <view class="game-tags">
          <text class="game-tag">{{item.rounds}}局</text>
          <text class="game-tag status-{{item.status}}">{{item.statusText}}</text>
        </view>
        <text class="game-date">{{item.formattedDate}}</text>
      </view>

      <!-- 右侧：积分 -->
      <view class="game-score-col">
        <text class="game-score {{item.myScore >= 0 ? 'score-win' : 'score-lose'}}">
          {{item.myScore >= 0 ? '+' : ''}}{{item.myScore}}
        </text>
        <text class="game-score-label">积分</text>
        <text class="game-team">{{item.myTeam}}队</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text class="load-more-text">{{loadingMore ? '加载中...' : '加载更多'}}</text>
    </view>
  </scroll-view>
</view>
