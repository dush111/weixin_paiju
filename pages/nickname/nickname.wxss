/* pages/nickname/nickname.wxss */
.nickname-container {
  min-height: 100vh;
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 60rpx;
}

.big-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(233,69,96,0.5);
}

.current-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
}

.current-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

.input-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.input-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  margin-bottom: 16rpx;
}

.name-input-wrap {
  position: relative;
  width: 100%;
}

.name-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(233,69,96,0.4);
  border-radius: 16rpx;
  padding: 0 90rpx 0 28rpx;
  font-size: 34rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.input-count {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}

.input-tip {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  margin-top: 12rpx;
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  font-size: 34rpx;
}

.save-btn.disabled {
  background: rgba(255,255,255,0.08);
  box-shadow: none;
  color: rgba(255,255,255,0.3);
}

.btn-cancel {
  width: 100%;
  height: 80rpx;
  background: transparent;
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 50rpx;
  color: rgba(255,255,255,0.4);
  font-size: 28rpx;
}

.btn-cancel::after { border: none; }
