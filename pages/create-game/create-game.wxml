<!-- pages/create-game/create-game.wxml -->
<view class="container create-container">
  <!-- 创建牌局步骤1 -->
  <view wx:if="{{step === 1}}" class="step-panel">
    <view class="step-header">
      <text class="step-title">新建牌局</text>
      <text class="step-desc">设置牌局名称，邀请3位好友开始</text>
    </view>

    <!-- 牌局名称 -->
    <view class="input-group">
      <text class="input-label">牌局名称</text>
      <input
        class="game-input"
        value="{{gameName}}"
        placeholder="例如：2024年春节局"
        maxlength="20"
        bindinput="onGameNameInput"
      />
    </view>

    <!-- 目标局数 -->
    <view class="input-group">
      <text class="input-label">计划局数</text>
      <view class="rounds-selector">
        <view
          class="rounds-btn {{targetRounds === item ? 'active' : ''}}"
          wx:for="{{roundOptions}}"
          wx:key="*this"
          data-val="{{item}}"
          bindtap="selectRounds"
        >{{item}}局</view>
      </view>
    </view>

    <button class="btn-primary create-btn" bindtap="createGame">
      创建牌局
    </button>
  </view>

  <!-- 等待玩家加入 -->
  <view wx:if="{{step === 2}}" class="step-panel waiting-panel">
    <view class="step-header">
      <text class="step-title">等待玩家加入</text>
      <text class="step-desc game-name-text">{{gameName}}</text>
    </view>

    <!-- 二维码区域 -->
    <view class="qr-section">
      <view class="qr-box">
        <image class="qr-image" src="{{qrCodeUrl || '/assets/images/qr-placeholder.png'}}" mode="aspectFit"></image>
        <text class="qr-tip">扫码加入牌局</text>
      </view>
    </view>

    <!-- 口令展示 -->
    <view class="code-display-box" bindtap="copyGameCode">
      <text class="code-display-label">口令</text>
      <text class="code-display-value">{{gameCode}}</text>
      <text class="code-display-copy">点击复制</text>
    </view>

    <!-- 邀请方式 -->
    <view class="invite-actions">
      <button class="btn-invite" open-type="share" bindtap="onInviteShare">
        <text class="invite-icon">📤</text>
        <text>微信邀请</text>
      </button>
      <button class="btn-invite btn-copy" bindtap="copyGameCode">
        <text class="invite-icon">📋</text>
        <text>复制口令</text>
      </button>
    </view>

    <!-- 玩家列表 -->
    <view class="players-section">
      <view class="players-header">
        <text class="players-title">玩家列表</text>
        <text class="players-count">{{filledPlayers.length}}/4</text>
      </view>

      <view class="players-grid">
        <view
          class="player-slot filled"
          wx:for="{{filledPlayers}}"
          wx:key="index"
        >
          <view class="player-item">
            <image class="player-avatar {{item.isBot ? 'bot-avatar' : ''}}" src="{{item.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
            <text class="player-name">{{item.nickname}}</text>
            <view class="player-tag {{index === 0 ? 'host-tag' : (item.isBot ? 'bot-tag' : 'joined-tag')}}">
              {{index === 0 ? '房主' : (item.isBot ? '自动填入' : '已加入')}}
            </view>
            <!-- 房主选择队友：非房主位置可点击标记为队友 -->
            <view
              wx:if="{{index !== 0}}"
              class="teammate-btn {{teammateIndex === index ? 'teammate-selected' : ''}}"
              bindtap="selectTeammate"
              data-index="{{index}}"
            >{{teammateIndex === index ? '✓ 我的队友' : '设为队友'}}</view>
          </view>
        </view>
      </view>

      <!-- 队伍预览 -->
      <view class="team-preview" wx:if="{{teammateIndex >= 0}}">
        <view class="team-preview-row">
          <text class="team-preview-label team-a-label">A队（我方）</text>
          <text class="team-preview-names">{{teamANames}}</text>
        </view>
        <view class="team-preview-row">
          <text class="team-preview-label team-b-label">B队（对方）</text>
          <text class="team-preview-names">{{teamBNames}}</text>
        </view>
      </view>
    </view>

    <!-- 一键填满 -->
    <button
      class="btn-fill-bots"
      wx:if="{{filledPlayers.length < 4}}"
      bindtap="fillBots"
    >一键填满（自动填入电脑玩家）</button>

    <!-- 开始按钮 -->
    <view class="start-section">
      <button
        class="btn-primary start-btn {{(filledPlayers.length < 4 || teammateIndex < 0) ? 'disabled' : ''}}"
        disabled="{{filledPlayers.length < 4 || teammateIndex < 0}}"
        bindtap="startGame"
      >
        <block wx:if="{{filledPlayers.length < 4}}">等待玩家加入({{filledPlayers.length}}/4)</block>
        <block wx:elif="{{teammateIndex < 0}}">请选择你的队友</block>
        <block wx:else>开始记分！</block>
      </button>
      <button class="btn-cancel" bindtap="cancelGame">取消牌局</button>
    </view>
  </view>
</view>
