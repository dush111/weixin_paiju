/* 全局样式 */
page {
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

/* 颜色变量（通过class模拟） */
/* 主色：#e94560 红色 */
/* 次色：#1a1a2e 深蓝黑 */
/* 辅色：#16213e 深蓝 */
/* 强调：#0f3460 中蓝 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* 通用卡片 */
.card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.card-white {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #e94560, #c0392b);
  color: #ffffff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.4);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.btn-secondary::after {
  border: none;
}

.btn-ghost {
  background: transparent;
  color: #e94560;
  border-radius: 50rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  border: 2rpx solid #e94560;
}

.btn-ghost::after {
  border: none;
}

/* 文字 */
.text-white { color: #ffffff; }
.text-gray { color: rgba(255,255,255,0.6); }
.text-red { color: #e94560; }
.text-gold { color: #f5c518; }

/* 标题 */
.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 24rpx 0;
}

/* 徽章 */
.badge {
  display: inline-block;
  background: #e94560;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* flex工具 */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }

/* 加载动画 */
.loading-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e94560;
  animation: dot-blink 1.4s infinite ease-in-out;
}

@keyframes dot-blink {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: rgba(255,255,255,0.4);
}

.empty-state image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-state text {
  font-size: 28rpx;
}
